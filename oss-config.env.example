# OSS配置环境变量
# 复制此文件为 .env 或 oss-config.env 并填入实际的配置值

# ====================================================================
# 访问密钥配置（必填）
# ====================================================================

# 必填：从阿里云控制台获取的访问密钥ID
# 用途：用于标识用户身份，是调用OSS API的身份凭证
# 获取路径：阿里云控制台 -> 访问控制 -> RAM用户 -> 选择用户 -> 用户AccessKey
OSS_ACCESS_KEY_ID=your_access_key_id_here

# 必填：从阿里云控制台获取的访问密钥Secret
# 用途：与AccessKey ID配对使用，用于验证API请求的合法性
# 注意：请妥善保管，避免泄露
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here

# ====================================================================
# Bucket配置（必填）
# ====================================================================

# 必填：OSS Bucket名称
# 用途：您创建的存储空间名称，所有OSS资源都存储在Bucket中
# 获取路径：阿里云控制台 -> 对象存储OSS -> 选择或创建Bucket
OSS_BUCKET=your_bucket_name

# ====================================================================
# 区域和Endpoint配置（必填）
# ====================================================================

# 必填：OSS服务器地址（Endpoint）
# 用途：OSS服务的访问域名，用于连接到OSS服务
# 格式：https://oss-{region}.aliyuncs.com
# 常见region示例：
# 杭州：oss-cn-hangzhou.aliyuncs.com
# 北京：oss-cn-beijing.aliyuncs.com
# 上海：oss-cn-shanghai.aliyuncs.com
# 深圳：oss-cn-shenzhen.aliyuncs.com
# 香港：oss-cn-hongkong.aliyuncs.com
# 美国西部：oss-us-west-1.aliyuncs.com
# 新加坡：oss-ap-southeast-1.aliyuncs.com
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# 可选：区域标识
# 用途：指定Bucket所在的区域，通常与endpoint中的region一致
# 格式：oss-{region}，例如：oss-cn-hangzhou
OSS_REGION=oss-cn-hangzhou

# ====================================================================
# 自定义域名配置（可选）
# ====================================================================

# 可选：自定义域名（如果使用了自定义域名）
# 用途：如果您为OSS Bucket绑定了自定义域名，则启用此项
# 例如：cdn.yourdomain.com
# 注意：需要先在阿里云OSS控制台完成域名绑定配置
# OSS_CNAME=your-custom-domain.com