# ====================================================================
# 服务器配置
# ====================================================================
PORT=3001

# ====================================================================
# 阿里云 OSS 配置
# ====================================================================

# 必填：访问密钥ID（从阿里云控制台 -> RAM用户 -> AccessKey 获取）
OSS_ACCESS_KEY_ID=your_access_key_id_here

# 必填：访问密钥Secret
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here

# 必填：OSS Bucket 名称
OSS_BUCKET=your_bucket_name

# 必填：OSS Endpoint，格式：https://oss-{region}.aliyuncs.com
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# 可选：区域标识
OSS_REGION=oss-cn-hangzhou

# 可选：自定义域名
# OSS_CNAME=cdn.yourdomain.com

# ====================================================================
# DeepSeek AI 配置
# ====================================================================

# 必填：DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 可选：API 地址
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 可选：默认模型
DEEPSEEK_MODEL=deepseek-chat

# ====================================================================
# Ollama AI 配置
# ====================================================================

# 可选：Ollama 服务地址（本地默认：http://localhost:11434）
OLLAMA_BASE_URL=http://localhost:11434

# 可选：云端 Ollama API Key
# OLLAMA_API_KEY=your_ollama_api_key_here

# 可选：默认模型
OLLAMA_DEFAULT_MODEL=llama3.1:8b